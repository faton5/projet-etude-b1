# ─── Environnement ───────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=info
DEMO_MODE=true

# ─── Ports locaux ────────────────────────────────────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ─── URLs API ────────────────────────────────────────────────────────────────
# URL publique (embarquée au build Next.js, visible côté client)
NEXT_PUBLIC_API_URL=http://localhost:8000
# URL interne Docker (côté serveur Next.js uniquement)
INTERNAL_API_URL=http://backend:8000

# ─── CORS ────────────────────────────────────────────────────────────────────
# Production Azure : https://potager-frontend.<id>.<region>.azurecontainerapps.io
CORS_ORIGINS=http://localhost:3000

# ─── Base de données SQLite ───────────────────────────────────────────────────
POTAGER_DB_PATH=/data/potager.db

# ─── Météo Open-Meteo (aucune clé requise) ───────────────────────────────────
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1/forecast
OPEN_METEO_GEOCODING_URL=https://geocoding-api.open-meteo.com/v1/search
DEFAULT_LOCATION=Rennes
DEFAULT_LATITUDE=48.1173
DEFAULT_LONGITUDE=-1.6778

# ─── Modèle ML ───────────────────────────────────────────────────────────────
MODEL_PATH=/app/models/xgboost_tomate.joblib

MQTT_ENABLED=true
MQTT_HOST=mqtt
MQTT_PORT=1883
MQTT_TOPIC_ROOT=farm/tomato
FARM_ID=farm_1
DEFAULT_SOIL_TYPE=limoneux
DEFAULT_IRRIGATION=goutte_a_goutte

# ─── Azure (remplir lors du déploiement) ─────────────────────────────────────
# ACR_NAME=potagerehpadacr
# RESOURCE_GROUP=rg-potager-ehpad
# LOCATION=francecentral
# BACKEND_IMAGE=potagerehpadacr.azurecr.io/potager-backend:v1
# FRONTEND_IMAGE=potagerehpadacr.azurecr.io/potager-frontend:v1
